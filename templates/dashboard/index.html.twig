{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<h1>Bonjour {{ app.user.firstName }}</h1>

<div class="row mt-4">

    {# SESSIONS #}
    <div class="col-md-3">
        <div class="card p-3">
            <h5>Entraînements</h5>
            <p>{{ trainingSessions|length }}</p>
        </div>
    </div>

    {# COMBATS #}
    <div class="col-md-3">
        <div class="card p-3">
            <h5>Combats</h5>
            <p>{{ fights|length }}</p>
        </div>
    </div>

    {# MEMBRES #}
    <div class="col-md-3">
        <div class="card p-3">
            <h5>Membres</h5>
            <p>{{ members|length }}</p>

            <a href="{{ path('app_user_index') }}" class="btn btn-sm btn-primary mt-2">
                Voir
            </a>
        </div>
    </div>

</div>

<hr>

<h3 class="mt-4">Activités</h3>
<ul>
    {% for activity in activities %}
        <li>{{ activity.name }}</li>
    {% endfor %}
</ul>

<h3 class="mt-4">Prochaines sessions</h3>
<ul>
    {% for session in trainingSessions %}
        <li>
            {{ session.activity.name }} : 
            {% for day in session.days %}
                    {{ day.value }}{% if not loop.last %}, {% endif %}
            {% endfor %}
            {{ session.startTime|date('H:i') }}-{{ session.endTime|date('H:i') }} -
            {{ session.location }}
        </li>
    {% endfor %}
</ul>

<h3 class="mt-4">Combats récents</h3>
<ul>
    {% for fight in fights %}
        <li>{{ fight.opponent1.lastName }} vs {{ fight.opponent2.lastName }}</li>
    {% endfor %}
</ul>

{% endblock %}