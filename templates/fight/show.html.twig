{% extends 'base.html.twig' %}

{% block title %}Fight{% endblock %}

{% block body %}
    <h1>Fight</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ fight.id }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ fight.date ? fight.date|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Opponent1</th>
                <td>{{ fight.opponent1 }}</td>
            </tr>
            <tr>
                <th>Opponent2</th>
                <td>{{ fight.opponent2 }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_fight_index') }}">back to list</a>

    <a href="{{ path('app_fight_edit', {'id': fight.id}) }}">edit</a>

    {{ include('fight/_delete_form.html.twig') }}
{% endblock %}
